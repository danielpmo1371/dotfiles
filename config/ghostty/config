custom-shader-animation = always

# No font-family: Ghostty's embedded JetBrains Mono (+ Nerd Font symbols) is the
# default on every platform, so macOS and Linux render identically with no font
# install. "SF Mono" never resolved anyway — Apple hides it from third-party apps.
font-size = 19
font-thicken = true
# theme = light:Xcode Light hc,dark:Xcode Dark hc
quick-terminal-animation-duration = 0
keybind = global:super+grave_accent=toggle_quick_terminal
cursor-style = block
shell-integration-features = no-cursor
cursor-style-blink = false
link-url = true
window-inherit-working-directory = true
window-inherit-font-size = true
window-theme = system
clipboard-trim-trailing-spaces = true
mouse-hide-while-typing = true
macos-titlebar-proxy-icon = hidden
macos-icon = custom-style
macos-icon-frame = plastic
macos-icon-ghost-color = FFFFFF
macos-icon-screen-color = 000000

# Window paddin2
window-padding-x = 20,20
window-padding-y = 20,20   

# Scrolling keybinds
# Page scrolling (standard terminal keybinds)
keybind = shift+page_up=scroll_page_up
keybind = shift+page_down=scroll_page_down

# Line scrolling for precise control
#keybind = shift+up=scroll_line_up
#keybind = shift+down=scroll_line_down

# Jump to top/bottom of scrollback
keybind = shift+home=scroll_to_top
keybind = shift+end=scroll_to_bottom

# Alternative vim-style scrolling
keybind = ctrl+u=scroll_page_up
keybind = ctrl+d=scroll_page_down

# Configure Option key as Meta for tmux prefix
macos-option-as-alt = true

# Decrease_font_size
keybind = ctrl+-=decrease_font_size:1
keybind = super+\=decrease_font_size:1

# SSH TERM variable Option
term = xterm-256color

# ─────────────────────────────────────────────────────────────────────────────
#   Cmd → Meta adapter
# ─────────────────────────────────────────────────────────────────────────────
# Ghostty is a thin adapter only: Cmd+<key> emits the same ESC-prefix (meta)
# bytes that Alt+<key> produces natively on Linux and Option+<key> already
# produces here (macos-option-as-alt). All SEMANTICS live in repo-tracked
# config — tmux.conf (prefix2 M-e, popups, vim-aware pane nav, M-u scrollback)
# and the meta blocks in zshrc/bashrc. Cmd ≡ Option ≡ Alt everywhere.
# Only keys with a bound consumer are mapped: an unbound meta key in a
# vi-mode shell falls through to vi-command execution (destructive).
keybind = super+e=text:\x1be
keybind = super+a=text:\x1ba
keybind = super+q=text:\x1bq
keybind = super+w=text:\x1bw
keybind = super+r=text:\x1br
keybind = super+u=text:\x1bu
keybind = super+d=text:\x1bd
keybind = super+i=text:\x1bi
keybind = super+n=text:\x1bn
keybind = super+h=text:\x1bh
keybind = super+j=text:\x1bj
keybind = super+k=text:\x1bk
keybind = super+l=text:\x1bl

# Kernel tty semantics — these MUST stay literal control bytes; no shell or
# tmux binding can raise SIGINT/SIGTSTP. EOF stays on physical Ctrl+D.
keybind = super+c=text:\x03
keybind = super+z=text:\x1A
# Cmd+V deliberately unmapped: native macOS paste.

# ─────────────────────────────────────────────────────────────────────────────
#   Tmux Window/Session Navigation with Cmd+Shift+h/j/k/l
# ─────────────────────────────────────────────────────────────────────────────
# Map Cmd+Shift+hjkl to escape sequences for Shift+Arrow keys
# NOTE: Ghostty does not support trailing comments — anything after `text:`
# (including a `# comment`) is sent literally to the terminal.
# Shift+Left (prev window)
keybind = super+[=text:\x1b[1;2D
# Shift+Right (next window)
keybind = super+]=text:\x1b[1;2C
# Ctrl+Shift+Left (move window left)
keybind = super+shift+[=text:\x1b[1;6D
# Ctrl+Shift+Right (move window right)
keybind = super+shift+]=text:\x1b[1;6C
# Shift+Left
keybind = super+shift+h=text:\x1b[1;2D
# Shift+Right
keybind = super+shift+l=text:\x1b[1;2C
# Shift+Down
keybind = super+shift+j=text:\x1b[1;2B
# Shift+Up
keybind = super+shift+k=text:\x1b[1;2A
