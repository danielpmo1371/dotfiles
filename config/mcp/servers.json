{
  "memory": {
    "type": "http",
    "url": "http://memory-mcp:8000/mcp"
  },
  "browser-network": {
    "type": "sse",
    "url": "http://10.0.0.102:3002/sse"
  },
  "azure-devops": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "@azure-devops/mcp", "mbie-immigrationnz-prod", "--authentication", "envvar"],
    "env": {
      "AZURE_DEVOPS_ORG_URL": "https://dev.azure.com/mbie-immigrationnz-prod",
      "AZURE_DEVOPS_AUTH_METHOD": "pat",
      "AZURE_DEVOPS_PAT": "secret:AZDO_PAT",
      "AZURE_DEVOPS_DEFAULT_PROJECT": "Travel Declaration",
      "ADO_MCP_AUTH_TOKEN": "secret:AZDO_PAT"
    }
  },
  "sequential-thinking": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "u/modelcontextprotocol/server-sequential-thinking"]
  },
  "puppeteer": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "u/modelcontextprotocol/server-puppeteer"]
  },
  "fetch": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "u/kazuph/mcp-fetch"]
  },
  "browser-local": {
    "type": "stdio",
    "command": "npx",
    "args": ["@browsermcp/mcp@latest"]
  }
}
